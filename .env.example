# Copier en .env.local et remplir. .env.local n'est jamais committé.

# --- Formulaire de séance d'essai (Resend) ---
RESEND_API_KEY=
# Doit appartenir à un domaine vérifié dans Resend.
TRIAL_FROM_EMAIL=reservation@court-circuit-coaching.fr
TRIAL_TO_EMAIL=court.circuit.coaching@gmail.com

# --- Avis Google (Places API New) ---
# Clé : console.cloud.google.com → activer « Places API (New) », puis
# restreindre la clé à cette seule API. Sans ces deux variables, le site
# retombe sur les valeurs statiques de lib/google-reviews.ts.
GOOGLE_PLACES_API_KEY=
# Identifiant de la fiche Google Business du club (commence par ChIJ…).
GOOGLE_PLACE_ID=

# --- Feed Instagram ---
# ⚠️ L'API Instagram Basic Display a été fermée par Meta le 4 décembre 2024.
# On utilise « Instagram API with Instagram Login » (graph.instagram.com), qui
# impose que @courtcircuit.coaching soit un compte PROFESSIONNEL ou CRÉATEUR
# (Paramètres Instagram → Type de compte). Un compte personnel ne peut pas.
#
# Mise en place : developers.facebook.com → créer une app → produit
# « Instagram » → Instagram Login → générer un jeton longue durée.
#
# ⚠️ Le jeton expire au bout de 60 JOURS. Le rafraîchir avant échéance
# (voir refreshInstagramToken dans lib/instagram.ts), sinon la section
# disparaît du site sans autre signal qu'une ligne dans les logs.
INSTAGRAM_ACCESS_TOKEN=
# ID numérique du compte Instagram professionnel.
INSTAGRAM_USER_ID=
